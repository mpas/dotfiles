# General
alias cp='cp -iv'
alias mv='mv -iv'
alias mkdir='mkdir -pv'
alias ls="ls -Al"
alias h=history
alias e="$EDITOR"
alias v="$VISUAL"
alias eb='e ~/.zshrc'
alias rb='source ~/.zshrc'
alias f='open -a Finder ./'
alias c='clear'
alias nvim=lvim
# vi/vim/nvim
alias vi=lvim
alias vim=lvim
